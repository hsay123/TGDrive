# Server
PORT=3001
NODE_ENV=development

# Database path (defaults to ./data/licenses.db)
DB_PATH=./data/licenses.db

# Secret for admin API endpoints
ADMIN_SECRET=change-this-to-a-random-string

# License server URL (used by the desktop app)
# In production: https://api.televault.app
SERVER_URL=http://localhost:3001

# TODO: Payment gateway credentials will go here in a future phase
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
