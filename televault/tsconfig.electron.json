{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/*"],
      "@electron/*": ["electron/*"]
    }
  },
  "include": ["electron/**/*", "core/**/*"],
  "exclude": ["node_modules", "dist", "dist-electron", "release", "src"]
}
